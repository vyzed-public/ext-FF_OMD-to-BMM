{
  "manifest_version": 2,
  "name": "OMD-to-BMM",
  "version": "0.3.0",
  "description": "Import Obsidian markdown links and plain URLs as Firefox bookmarks.",
  "browser_specific_settings": {
    "gecko": {
      "id": "omd2bmm@vyzed.net"
    }
  },
  "permissions": [
    "bookmarks",
    "storage"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "OMD-to-BMM: Import bookmarks from Obsidian"
  },
  "sidebar_action": {
    "default_title": "OMD-to-BMM Bookmarks",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
